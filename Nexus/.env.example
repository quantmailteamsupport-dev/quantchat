# QuantChat environment variables reference
# Copy this file to .env and replace every placeholder locally.

# App
NODE_ENV=<set-node-env>
PORT=<set-port>
LOG_LEVEL=info

# Database (PostgreSQL + Prisma)
DATABASE_URL=<replace-with-quantchat-database-url>

# Redis (Socket.io adapter + caching)
REDIS_URL=<set-redis-url>

# CORS
CORS_ORIGINS=<set-cors-origins>

# Quantmail biometric SSO
QUANTMAIL_JWT_SECRET=<replace-with-quantmail-jwt-secret>
QUANTMAIL_ISSUER=<set-quantmail-issuer>
ALLOW_INSECURE_SOCKET_AUTH=false
NEXT_PUBLIC_QUANTMAIL_DEV_JWT=<optional-local-dev-jwt>

# AI / Digital Twin
OPENAI_API_KEY=<optional-openai-api-key>
OPENAI_MODEL=<set-openai-model>

# AWS S3 (media attachments)
AWS_REGION=<set-aws-region>
AWS_ACCESS_KEY_ID=<replace-with-aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<replace-with-aws-secret-access-key>
S3_BUCKET=<replace-with-s3-bucket>
CDN_BASE_URL=<replace-with-cdn-base-url>

# Translation service
DEEPL_API_KEY=<optional-deepl-api-key>
TRANSLATION_PROVIDER=deepl

# Push notifications
FCM_SERVER_KEY=<optional-fcm-server-key>
APNS_KEY_ID=<optional-apns-key-id>
APNS_TEAM_ID=<optional-apns-team-id>
APNS_PRIVATE_KEY_PATH=<optional-apns-private-key-path>

# Admin
ADMIN_SECRET=<replace-with-admin-secret>

# Biometric providers
FACETEC_SDK_KEY=<optional-facetec-sdk-key>
INCODE_API_KEY=<optional-incode-api-key>
INCODE_API_URL=<set-incode-api-url>
