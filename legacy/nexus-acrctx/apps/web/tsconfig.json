{
  "extends": "../../packages/typescript-config/nextjs.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@repo/database": ["../../packages/database/src/index.ts"],
      "@repo/database/*": ["../../packages/database/src/*"],
      "@repo/security": ["../../packages/security/src/index.ts"],
      "@repo/security/*": ["../../packages/security/src/*"],
      "@repo/ui/*": ["../../packages/ui/src/*"],
      "@infinity-trinity/shared-kernel/*": [
        "../../../../shared-kernel/dist/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "next.config.js",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
