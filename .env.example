# QuantChat environment template
# Copy to .env or the relevant Nexus app env file and replace values locally.

NODE_ENV=<set-node-env>
PORT=<set-port>
LOG_LEVEL=info

# Core persistence and cache
DATABASE_URL=<replace-with-quantchat-database-url>
REDIS_URL=<set-redis-url>

# Auth and ecosystem SSO
QUANTMAIL_SSO_URL=<set-quantmail-sso-url>
QUANTMAIL_JWT_SECRET=<replace-with-quantmail-jwt-secret>
JWT_SECRET=<replace-with-jwt-secret>

# Realtime/WebRTC
WEBRTC_ICE_SERVERS=<set-webrtc-ice-servers>
NEXT_PUBLIC_API_URL=<set-public-api-url>
NEXT_PUBLIC_WS_URL=<set-public-ws-url>

# Optional AI features
OPENAI_API_KEY=<optional-openai-api-key>
