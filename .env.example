# QuantChat — example environment file
# Copy to .env (which is gitignored) and fill in real values.
# For production deployment, put these values in GitHub Actions Secrets
# (see docs/SECRETS_REQUIRED.md).

# ─── Database ─────────────────────────────────────────────────────────
DB_PASSWORD=change-me
DB_NAME=quantchat
MONGO_URL=mongodb://localhost:27017
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=change-me

# ─── Auth / JWT ───────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
NEXTAUTH_SECRET=change-me-to-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# ─── Admin seed (Python backend) ──────────────────────────────────────
# REQUIRED — backend will refuse to start without this set.
ADMIN_EMAIL=admin@quantchat.com
ADMIN_PASSWORD=change-me

# ─── OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Firebase (admin) ─────────────────────────────────────────────────
# Pass either a path to a service-account JSON file OR the JSON content
# inline (recommended for CI/CD via a single secret).
FIREBASE_PROJECT_ID=
FIREBASE_WEB_API_KEY=
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_SERVICE_ACCOUNT_JSON=

# ─── OpenAI / LLM ─────────────────────────────────────────────────────
OPENAI_API_KEY=
EMERGENT_LLM_KEY=

# ─── Frontend / Next.js public ────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_QUANTCHAT_API_URL=http://localhost:3001
NEXT_PUBLIC_QUANTMAIL_API_URL=
NEXT_PUBLIC_QUANTMAIL_DEV_JWT=
NEXT_PUBLIC_CHAT_USER_ID=
NEXT_PUBLIC_STRIPE_CHECKOUT_URL=
NEXT_PUBLIC_TURN_USER=
NEXT_PUBLIC_TURN_CRED=

# ─── AWS / S3 ─────────────────────────────────────────────────────────
AWS_REGION=us-east-1
S3_BUCKET=
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false
CDN_BASE_URL=

# ─── Misc service tuning ──────────────────────────────────────────────
LOG_LEVEL=info
PORT=3001
POI_SIGNING_SECRET=
ALLOW_INSECURE_SOCKET_AUTH=false
COMPANION_SESSION_TTL_MS=86400000
COMPANION_SESSION_MAX_PER_USER=10
COMPANION_SESSION_REDIS_PRUNE_INTERVAL_MS=60000
COMPANION_SESSION_WRITE_THROTTLE_MS=1000
QUEUE_RECOVERY_BACKLOG_THRESHOLD=100
QUEUE_RECOVERY_CACHE_MS=5000
QUEUE_RECOVERY_DRIFT_THRESHOLD_MS=30000
REALTIME_TELEMETRY_LOG_INTERVAL_MS=60000
