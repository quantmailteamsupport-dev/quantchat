# Copy to terraform.tfvars (which is gitignored) and fill in real values.
# Or pass via TF_VAR_<name> environment variables.

aws_region     = "us-east-1"
instance_type  = "t3.medium"

# Paste the contents of your ~/.ssh/id_ed25519.pub here (one line).
ssh_pubkey = "ssh-ed25519 AAAA... your-key-comment"

# Restrict SSH to your home/office IP for security. Default is open to the world.
# ssh_cidr_blocks = ["1.2.3.4/32"]
